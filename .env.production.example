# Production env — copy into Render + Vercel dashboards
# Replace YOURDOMAIN.com with your real domain (e.g. voicetalk.com)
# See docs/DEPLOY-DOMAIN.md

# --- Render (apps/server) ---
DATABASE_URL=postgresql://postgres.envvljswvktowabeukrq:YOUR_DB_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://envvljswvktowabeukrq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...from-supabase-project-settings-api-service_role
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-live-preview
JWT_SECRET=generate-with-openssl-rand-hex-32
ALLOWED_ORIGINS=https://app.YOURDOMAIN.com,https://admin.YOURDOMAIN.com,https://YOURDOMAIN.com

# --- Vercel customer-app (root: apps/customer-app) ---
NEXT_PUBLIC_API_URL=https://api.YOURDOMAIN.com
NEXT_PUBLIC_WS_URL=wss://api.YOURDOMAIN.com/ws/session

