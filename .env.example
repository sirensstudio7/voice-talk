GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-live-preview
API_PORT=8000
# Supabase Postgres (use connection pooler URL, port 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
JWT_SECRET=dev-secret-change-in-production
# Production: comma-separated CORS entries (full URLs, hostnames, or domains)
# ALLOWED_ORIGINS=https://app.yourdomain.com,admin.yourdomain.com,yourdomain.com
DEFAULT_BUSINESS_SLUG=sunrise-coffee
ADMIN_EMAIL=admin@sunrise.coffee
ADMIN_PASSWORD=admin123
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/session
NEXT_PUBLIC_CUSTOMER_APP_URL=http://localhost:6670
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:6680
NEXT_PUBLIC_MARKETING_APP_URL=http://localhost:6690
# Optional fallback only — Eva uses 3D by default
# NEXT_PUBLIC_USE_PNG_AVATAR=true
